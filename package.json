{
  "name": "smart-fold",
  "displayName": "Smart Fold",
  "publisher": "naveed-toro",
  "description": "The smartest way to handle code folding in VS Code. Hide the code to read the comments, or hide the comments to write the code.",
  "version": "0.0.1",
  "repository": {
  "type": "git",
  "url": "https://github.com/naveed-toro/smart-fold-vscode.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartfold.toggleAll",
        "title": "Smart Fold: Clean Slate (Hide All)"
      },
      {
        "command": "smartfold.toggleCode",
        "title": "Smart Fold: Reading Mode (Hide Code)"
      },
      {
        "command": "smartfold.toggleComments",
        "title": "Smart Fold: Coding Mode (Hide Comments)"
      },
      {
          "command": "smartfold.toggleComments",
          "title": "Smart Fold: Coding Mode (Hide Comments)"
        },
        {
          "command": "smartfold.toggleCurrent",
          "title": "Smart Fold: Toggle Current Line (Pack/Unpack)"
        }
    ],
    "keybindings": [
      {
        "command": "smartfold.toggleAll",
        "key": "alt+z",
        "mac": "alt+z"
      },
      {
        "command": "smartfold.toggleCode",
        "key": "alt+x",
        "mac": "alt+x"
      },
      {
        "command": "smartfold.toggleComments",
        "key": "alt+c",
        "mac": "alt+c"
      },
      {
          "command": "smartfold.toggleComments",
          "key": "alt+c",
          "mac": "alt+c"
        },
        {
          "command": "smartfold.toggleCurrent",
          "key": "alt+s",
          "mac": "alt+s"
        }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
